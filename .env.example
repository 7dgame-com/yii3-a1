# MrPP API - Environment Configuration
# Copy this file to .env and update the values for your environment.

# MySQL Database
MYSQL_HOST=localhost
MYSQL_DB=mrpp
MYSQL_USER=root
MYSQL_PASS=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# JWT - Path to the secret key file used for HS256 signing
JWT_KEY=/path/to/jwt-secret.key

# Application
YII_DEBUG=false
YII_ENV=production
YII_CHECK_EVENTS=false
