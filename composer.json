{
    "name": "mrpp/api",
    "description": "MrPP - Mixed Reality Platform REST API (Yii3)",
    "type": "project",
    "license": "GPL-3.0-only",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "yiisoft/yii-http": "^1.0",
        "yiisoft/router": "^3.0",
        "yiisoft/router-fastroute": "^3.0",
        "yiisoft/di": "^1.2",
        "yiisoft/config": "^1.3",
        "yiisoft/db": "^2.0",
        "yiisoft/db-mysql": "^2.0",
        "yiisoft/active-record": "^1.0",
        "yiisoft/cache": "^3.0",
        "yiisoft/cache-redis": "^2.0",
        "yiisoft/log": "^2.0",
        "yiisoft/log-target-file": "^3.0",
        "yiisoft/yii-middleware": "^1.0",
        "yiisoft/yii-runner-http": "^2.0",
        "yiisoft/error-handler": "^3.0",
        "yiisoft/yii-event": "^2.0",
        "yiisoft/injector": "^1.2",
        "yiisoft/data-response": "^2.0",
        "yiisoft/request-body-parser": "^1.0",
        "lcobucci/jwt": "^5.0",
        "predis/predis": "^2.0",
        "vlucas/phpdotenv": "^5.5",
        "zircote/swagger-php": "^4.0",
        "httpsoft/http-message": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "giorgiosironi/eris": "^1.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/config": true
        }
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "config"
        },
        "config-plugin": {
            "params": [
                "params.php",
                "common/params.php",
                "web/params.php"
            ],
            "params-web": [
                "$params"
            ],
            "common": "common/*.php",
            "web": [
                "$common",
                "web/*.php"
            ],
            "di": [
                "common/di/*.php"
            ],
            "di-web": [
                "$di",
                "web/di/*.php"
            ],
            "routes": "web/routes.php",
            "bootstrap-web": "web/bootstrap.php"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
